<!-- 3. UI DESIGN (app/src/main/res/layout/activity_main.xml) -->
<!-- ========================================== -->
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    android:padding="20dp">

    <!-- Modern Digital Clock Display -->
    <androidx.cardview.widget.CardView
        android:id="@+id/clockCard"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="30dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextClock
                android:id="@+id/textClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="hh:mm:ss a"
                android:textColor="#2D3748"
                android:textSize="38sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="বর্তমান সময় (Current Time)"
                android:textColor="#718096"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Customized Input Field -->
    <EditText
        android:id="@+id/etAlarmMessage"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_below="@id/clockCard"
        android:layout_marginTop="40dp"
        android:background="@android:drawable/editbox_background"
        android:hint="অ্যালার্মের সময় যা পড়ে শোনাবে..."
        android:paddingLeft="15dp"
        android:paddingRight="15dp"
        android:inputType="text"
        android:textColor="#2D3748"
        android:textSize="16sp" />

    <!-- Action Button -->
    <Button
        android:id="@+id/btnSelectTime"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_below="@id/etAlarmMessage"
        android:layout_marginTop="25dp"
        android:backgroundTint="#4F46E5"
        android:text="অ্যালার্ম সেট করুন"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="14dp" />

    <!-- Status Tracker -->
    <TextView
        android:id="@+id/tvAlarmStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnSelectTime"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="25dp"
        android:text="কোনো অ্যালার্ম একটিভ নেই"
        android:textColor="#E53E3E"
        android:textSize="15sp"
        android:textStyle="italic|bold" />
</RelativeLayout>

